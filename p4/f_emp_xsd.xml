<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet href="style.xsl" type="text/xsl"?>

<orgData xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xs="http://www.w3.org/2001/XMLSchema">
    <xs:schema>
        <xs:element name="orgData">
            <xs:complexType>
                <xs:sequence>
                    <xs:element name="xsd_employeesData">
                        <xs:complexType>
                            <xs:sequence>
                                <xs:element name="xsd_employee" maxOccurs="unbounded">
                                    <xs:complexType>
                                        <xs:sequence>
                                            <xs:element name="xsd_name" type="xs:string"/>
                                            <xs:element name="xsd_department" type="xs:string"/>
                                            <xs:element name="xsd_salary" type="xs:integer"/>
                                            <xs:element name="xsd_JoiningDate" type="xs:date"/>
                                        </xs:sequence>
                                        <xs:attribute name="xsd_id" type="xs:string" use="required"/>
                                    </xs:complexType>
                                </xs:element>
                            </xs:sequence>
                        </xs:complexType>
                    </xs:element>
                </xs:sequence>
            </xs:complexType>
        </xs:element>
    </xs:schema>
